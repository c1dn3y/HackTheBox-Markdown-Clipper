{
  "manifest_version": 3,
  "name": "HTB Markdown Clipper",
  "version": "1.0",
  "description": "Copy HackTheBox Enterprise code blocks as Markdown fences — via hover button or right-click. Perfect for Obsidian notes.",
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["contextMenus", "scripting"],
  "host_permissions": ["https://enterprise.hackthebox.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://enterprise.hackthebox.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
